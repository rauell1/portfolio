# Supabase Configuration
# Get these values from your Supabase project dashboard at https://app.supabase.com

# Your Supabase project URL (e.g., https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=your_supabase_project_url

# Your Supabase anonymous/public key (safe for client-side use)
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual Supabase credentials
# 3. Never commit the .env file to version control (it's already in .gitignore)
#
# To get your credentials:
# 1. Go to https://app.supabase.com
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the Project URL and anon/public key
